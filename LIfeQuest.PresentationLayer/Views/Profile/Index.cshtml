@{
    ViewData["Title"] = "User Profile";
}

<div class="row align-items-center mb-5">
    <div class="col-md-auto text-center">
        <div class="position-relative d-inline-block">
            <img class="rounded-circle border border-primary p-2 mb-3" src="https://ui-avatars.com/api/?name=Alex+Johnson&size=180&background=4e73df&color=fff" alt="Profile View" style="width: 180px;">
            <button class="btn btn-primary rounded-circle position-absolute bottom-0 end-0 p-2 shadow" style="transform: translate(-10%, -60%); width: 40px; height: 40px;">
                <i class="fas fa-camera fa-xs"></i>
            </button>
        </div>
    </div>
    <div class="col-md px-md-4">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h1 class="h3 fw-bold mb-1">Alex Johnson</h1>
                <p class="text-muted"><i class="fas fa-map-marker-alt me-1"></i> Cairo, Egypt | Full Stack Developer</p>
                <div class="mb-3">
                    <span class="level-badge me-2">Level 12</span>
                    <span class="badge bg-primary-subtle text-primary fw-bold">Pro Member</span>
                </div>
            </div>
            <button class="btn btn-outline-primary btn-sm px-4">Edit Profile</button>
        </div>
        
        <div class="row">
            <div class="col-md-8">
                <div class="d-flex justify-content-between mb-1">
                    <span class="small fw-bold">XP Level Progress</span>
                    <span class="small fw-bold">75% (750 / 1000 XP)</span>
                </div>
                <div class="progress shadow-sm" style="height: 15px;">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: 75%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Stats Column -->
    <div class="col-lg-4 mb-4">
        <div class="card shadow p-4 text-center">
             <div class="row">
                 <div class="col-6 mb-4">
                     <h3 class="fw-bold mb-0 text-primary">2,450</h3>
                     <span class="text-muted small">Total Points</span>
                 </div>
                 <div class="col-6 mb-4">
                     <h3 class="fw-bold mb-0 text-success">14</h3>
                     <span class="text-muted small">Current Streak</span>
                 </div>
                 <div class="col-6">
                     <h3 class="fw-bold mb-0 text-info">32</h3>
                     <span class="text-muted small">Quests Won</span>
                 </div>
                 <div class="col-6">
                     <h3 class="fw-bold mb-0 text-warning">8</h3>
                     <span class="text-muted small">Badges Earned</span>
                 </div>
             </div>
        </div>
        
        <div class="card shadow mt-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Your Interests</h6>
            </div>
            <div class="card-body">
                <span class="badge bg-primary me-1 mb-2 px-3 py-2">.NET Core</span>
                <span class="badge bg-primary me-1 mb-2 px-3 py-2">C# 14</span>
                <span class="badge bg-success me-1 mb-2 px-3 py-2">Running</span>
                <span class="badge bg-info me-1 mb-2 px-3 py-2">Modernism</span>
                <span class="badge bg-warning me-1 mb-2 px-3 py-2">Productivity</span>
            </div>
        </div>
    </div>

    <!-- Badges Column -->
    <div class="col-lg-8">
        <div class="card shadow">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Badge Collection</h6>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-4 col-md-3 mb-4">
                        <i class="fas fa-bolt fa-3x text-warning mb-2 d-block"></i>
                        <span class="small fw-bold">Speedrunner</span>
                    </div>
                    <div class="col-4 col-md-3 mb-4">
                        <i class="fas fa-trophy fa-3x text-warning mb-2 d-block"></i>
                        <span class="small fw-bold">Champion</span>
                    </div>
                    <div class="col-4 col-md-3 mb-4">
                        <i class="fas fa-shield-alt fa-3x text-primary mb-2 d-block"></i>
                        <span class="small fw-bold">Consistency</span>
                    </div>
                    <div class="col-4 col-md-3 mb-4">
                        <i class="fas fa-user-shield fa-3x text-info mb-2 d-block"></i>
                        <span class="small fw-bold">Guardian</span>
                    </div>
                    <div class="col-4 col-md-3 mb-4">
                        <i class="fas fa-gem fa-3x text-danger mb-2 d-block"></i>
                        <span class="small fw-bold">Rare Collector</span>
                    </div>
                    <!-- Empty / Locked Slots -->
                    <div class="col-4 col-md-3 mb-4 opacity-25">
                        <i class="fas fa-lock fa-3x text-secondary mb-2 d-block"></i>
                        <span class="small">Locked</span>
                    </div>
                    <div class="col-4 col-md-3 mb-4 opacity-25">
                        <i class="fas fa-lock fa-3x text-secondary mb-2 d-block"></i>
                        <span class="small">Locked</span>
                    </div>
                    <div class="col-4 col-md-3 mb-4 opacity-25">
                        <i class="fas fa-lock fa-3x text-secondary mb-2 d-block"></i>
                        <span class="small">Locked</span>
                    </div>
                </div>
            </div>
            <div class="card-footer text-center">
                <button class="btn btn-link text-decoration-none small">View All Milestone Rewards</button>
            </div>
        </div>
    </div>
</div>
