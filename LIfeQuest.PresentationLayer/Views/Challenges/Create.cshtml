@{
    ViewData["Title"] = "Create Challenge";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center mb-4">
            <a href="/Challenges/Index" class="btn btn-link text-decoration-none p-0 me-3"><i class="fas fa-arrow-left fa-lg"></i></a>
            <h1 class="h3 mb-0 text-gray-800">Create New Quest</h1>
        </div>

        <div class="card shadow">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Challenge Details</h6>
            </div>
            <div class="card-body">
                <form>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Title</label>
                        <input type="text" class="form-control" placeholder="e.g. Master C# Generics">
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Description</label>
                        <textarea class="form-control" rows="3" placeholder="What is your goal?"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold">Category</label>
                            <select class="form-select">
                                <option selected>Select Category</option>
                                <option>Technical</option>
                                <option>Health</option>
                                <option>Education</option>
                                <option>Art</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold">Duration (Days)</label>
                            <input type="number" class="form-control" placeholder="30">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold d-block">Difficulty</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="difficulty" id="easy" autocomplete="off">
                            <label class="btn btn-outline-success" for="easy">Easy</label>

                            <input type="radio" class="btn-check" name="difficulty" id="medium" autocomplete="off" checked>
                            <label class="btn btn-outline-warning" for="medium">Medium</label>

                            <input type="radio" class="btn-check" name="difficulty" id="hard" autocomplete="off">
                            <label class="btn btn-outline-danger" for="hard">Hard</label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch p-0 d-flex align-items-center justify-content-between">
                            <label class="form-check-label fw-bold" for="flexSwitchCheckChecked">Public Challenge</label>
                            <input class="form-check-input ms-0 mt-0" type="checkbox" role="switch" id="flexSwitchCheckChecked" checked style="width: 3rem; height: 1.5rem;">
                        </div>
                        <div class="text-muted small">Public challenges can be joined by others and appear in the leaderboard.</div>
                    </div>

                    <hr class="my-4">

                    <div class="d-grid">
                        <button type="button" class="btn btn-primary btn-lg shadow">Create Challenge</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
