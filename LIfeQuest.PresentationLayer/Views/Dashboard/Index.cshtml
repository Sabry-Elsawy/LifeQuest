@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Welcome back, Alex!</h1>
    <a href="/Challenges/Create" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50 mr-2"></i> New Challenge
    </a>
</div>

<div class="row">
    <!-- User Summary Card -->
    <div class="col-xl-8 col-lg-7">
        <div class="card shadow mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <img class="rounded-circle border border-primary p-1" src="https://ui-avatars.com/api/?name=Alex+Johnson&size=128&background=4e73df&color=fff" alt="User Large" style="width: 100px;">
                    </div>
                    <div class="col">
                        <h4 class="fw-bold mb-1">Alex Johnson</h4>
                        <div class="mb-2">
                            <span class="level-badge me-2">Level 12 Explorer</span>
                            <span class="text-muted small"><i class="fas fa-calendar-alt me-1"></i> Member since Jan 2026</span>
                        </div>
                        <div class="mb-1 d-flex justify-content-between">
                            <span class="small fw-bold">Next Level: 13</span>
                            <span class="small fw-bold text-primary">750 / 1000 XP</span>
                        </div>
                        <div class="progress mb-0" style="height: 12px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 75%" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="col-xl-4 col-lg-5">
        <div class="row">
            <div class="col-12">
                <div class="card border-left-success shadow h-100 py-2" style="border-left: 0.25rem solid var(--success-color) !important;">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Success Rate</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">88%</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 mt-3">
                <div class="card border-left-warning shadow h-100 py-2" style="border-left: 0.25rem solid var(--warning-color) !important;">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Current Streak</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">14 Days</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-fire fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Active Challenges -->
    <div class="col-xl-8 col-lg-7">
        <h5 class="fw-bold mb-3"><i class="fas fa-tasks me-2 text-primary"></i>Active Challenges</h5>
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0">Learn .NET 10</h6>
                            <span class="badge bg-danger-subtle text-danger border border-danger">Hard</span>
                        </div>
                        <p class="text-muted small mb-3">Master the new features of C# 14 and .NET 10.0.</p>
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="small text-muted">65% Completed</span>
                            <span class="small text-muted">4 Days Left</span>
                        </div>
                        <div class="progress mb-3">
                            <div class="progress-bar bg-info" role="progressbar" style="width: 65%"></div>
                        </div>
                        <a href="/Challenges/Details" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0">Daily 5km Run</h6>
                            <span class="badge bg-success-subtle text-success border border-success">Easy</span>
                        </div>
                        <p class="text-muted small mb-3">Maintain a healthy lifestyle by running every morning.</p>
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="small text-muted">20% Completed</span>
                            <span class="small text-muted">22 Days Left</span>
                        </div>
                        <div class="progress mb-3">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 20%"></div>
                        </div>
                        <a href="#" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                    </div>
                </div>
            </div>
        </div>

        <h5 class="fw-bold mb-3 mt-2"><i class="fas fa-medal me-2 text-warning"></i>Recent Badges</h5>
        <div class="card p-3 shadow-sm">
            <div class="row">
                <div class="col-4 col-md-2 badge-item">
                    <i class="fas fa-fire badge-icon text-warning"></i>
                    <span class="small fw-bold">7-Day Streak</span>
                </div>
                <div class="col-4 col-md-2 badge-item">
                    <i class="fas fa-star badge-icon text-info"></i>
                    <span class="small fw-bold">Level 10</span>
                </div>
                <div class="col-4 col-md-2 badge-item">
                    <i class="fas fa-code badge-icon text-primary"></i>
                    <span class="small fw-bold">Code Master</span>
                </div>
                <div class="col-4 col-md-2 badge-item opacity-25">
                    <i class="fas fa-lock badge-icon"></i>
                    <span class="small fw-bold">Locked</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Mini Leaderboard -->
    <div class="col-xl-4 col-lg-5">
        <h5 class="fw-bold mb-3"><i class="fas fa-list-ol me-2 text-primary"></i>Leaderboard</h5>
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 small">Rank</th>
                            <th class="border-0 small">User</th>
                            <th class="border-0 small">Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge bg-warning text-dark">1</span></td>
                            <td><img src="https://ui-avatars.com/api/?name=John+Doe&size=32" class="rounded-circle me-2" alt="">John Doe</td>
                            <td class="fw-bold">5,200</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-secondary">2</span></td>
                            <td><img src="https://ui-avatars.com/api/?name=Jane+Smith&size=32" class="rounded-circle me-2" alt="">Jane Smith</td>
                            <td class="fw-bold">4,850</td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-info">3</span></td>
                            <td><img src="https://ui-avatars.com/api/?name=Michael+Ray&size=32" class="rounded-circle me-2" alt="">Michael Ray</td>
                            <td class="fw-bold">4,100</td>
                        </tr>
                        <tr class="bg-primary bg-opacity-10">
                            <td><span class="fw-bold">12</span></td>
                            <td><img src="https://ui-avatars.com/api/?name=Alex+Johnson&size=32" class="rounded-circle me-2" alt="">Alex (You)</td>
                            <td class="fw-bold">2,450</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="card-footer text-center py-2">
                <a href="#" class="small text-decoration-none">View Full Leaderboard</a>
            </div>
        </div>
    </div>
</div>
