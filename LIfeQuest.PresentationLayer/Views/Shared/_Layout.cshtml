<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Life Quest</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar">
            <a href="/" class="sidebar-brand">
                <i class="fas fa-rocket me-2"></i> Life Quest
            </a>
            <hr class="mx-3 my-0 border-light opacity-10">
            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-th-large"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Challenges" ? "active" : "")" asp-controller="Challenges" asp-action="Index">
                        <i class="fas fa-trophy"></i> My Challenges
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="fas fa-globe"></i> Public Challenges
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Analytics" ? "active" : "")" asp-controller="Analytics" asp-action="Index">
                        <i class="fas fa-chart-line"></i> Analytics
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Profile" ? "active" : "")" asp-controller="Profile" asp-action="Index">
                        <i class="fas fa-user-circle"></i> Profile
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Content Content -->
        <div id="content-wrapper">
            <!-- Top Navbar -->
            <nav class="top-navbar bg-white">
                <div class="d-flex align-items-center w-100">
                    <button class="btn btn-link d-md-none me-3" id="sidebarToggle">
                        <i class="fa fa-bars"></i>
                    </button>
                    
                    <div class="ms-auto d-flex align-items-center">
                        <div class="me-4 d-none d-sm-inline-block">
                            <span class="points-indicator me-2"><i class="fas fa-coins"></i> 2,450 pts</span>
                            <span class="level-badge">LVL 12</span>
                        </div>
                        
                        <div class="dropdown me-3">
                            <a href="#" class="text-secondary position-relative" data-bs-toggle="dropdown">
                                <i class="fas fa-bell fa-lg"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.5rem;">3</span>
                            </a>
                        </div>
                        
                        <div class="d-flex align-items-center border-start ps-3">
                            <span class="me-2 d-none d-lg-inline text-gray-600 small fw-bold">Alex Johnson</span>
                            <img class="avatar-sm" src="https://ui-avatars.com/api/?name=Alex+Johnson&background=4e73df&color=fff" alt="User">
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Main Body -->
            <div class="container-fluid">
                @RenderBody()
            </div>

            <footer class="py-4 bg-white mt-auto border-top">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div class="text-muted">&copy; 2026 Life Quest Dashboard</div>
                        <div>
                            <a href="#">Privacy Policy</a>
                            &middot;
                            <a href="#">Terms &amp; Conditions</a>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
