@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Life Quest</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

    <div class="auth-wrapper">
        <div class="auth-card">
            <a href="/" class="auth-brand">
                <i class="fas fa-rocket me-2"></i> Life Quest
            </a>

            <div class="text-center mb-4">
                <h4 class="fw-bold mb-1">Welcome Back!</h4>
                <p class="text-muted small">Please enter your credentials to continue your quest.</p>
            </div>

            <form class="auth-form">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Email Address</label>
                    <input type="email" class="form-control" placeholder="name@example.com" required>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between">
                        <label class="form-label small fw-bold text-muted">Password</label>
                        <a href="#" class="small text-decoration-none">Forgot?</a>
                    </div>
                    <input type="password" class="form-control" placeholder="••••••••" required>
                </div>
                <div class="mb-4 form-check">
                    <input type="checkbox" class="form-check-input" id="rememberMe">
                    <label class="form-check-label small text-muted" for="rememberMe">Remember me on this device</label>
                </div>
                <div class="d-grid mb-4">
                    <a href="/Dashboard" class="btn btn-primary btn-lg shadow-sm fw-bold">Sign In</a>
                </div>

                <div class="text-center mb-4 position-relative">
                    <hr class="my-0">
                    <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 small text-muted">Or continue with</span>
                </div>

                <div class="row g-2 mb-4">
                    <div class="col-6">
                        <a href="#" class="social-auth-btn">
                            <i class="fab fa-google me-2 text-danger"></i> Google
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="#" class="social-auth-btn">
                            <i class="fab fa-github me-2 text-dark"></i> GitHub
                        </a>
                    </div>
                </div>

                <div class="text-center">
                    <p class="small text-muted mb-0">Don't have an account? <a href="/Account/Register" class="fw-bold text-decoration-none">Register</a></p>
                </div>
            </form>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
